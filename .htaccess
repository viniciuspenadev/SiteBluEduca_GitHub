<Files "config.php">
    Order Deny,Allow
    Deny from all
</Files>

RewriteEngine On

# 1. Redirect index.php to / (Canonicalization)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s(.*)/index\.php [NC]
RewriteRule ^ %1/ [R=301,L]

# 2. Redirect .php to extensionless (Force Friendly URLs)
# Only if the request is NOT a directory and NOT an internal rewrite
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# 3. Handle Friendly URLs availability (Internal Rewrite)
# Rewrite extensionless URL to .php file if it exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]
